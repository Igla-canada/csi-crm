# -----------------------------------------------------------------------------
# Supabase (required)
# Project Settings → API: URL and anon key; service role key (server-only, never expose to browser).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
# Anon or “publishable default” key (public, for client-side Supabase later).
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"
# Server-only: required for this CRM’s data layer. Settings → API → service_role (long secret, often starts with eyJ…).
# This is not the same as the anon/publishable key.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

# Direct Postgres for `npm run db:push` (Supabase CLI). Prefer Session pooler if CLI fails DNS on Windows:
# Dashboard → Database → Connection string → Session mode (host like aws-0-....pooler.supabase.com, port 5432).
# Plain db.[REF].supabase.co is often IPv6-only and can cause "no such host" / ENOTFOUND from the CLI.
# Optional: SUPABASE_CLI_DNS_RESOLVER=https (or native) if the CLI suggests trying another resolver.
# DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Optional: wipe all clients / calls / bookings / imports (keeps users + workspace settings).
# npm run db:wipe:confirm
#
# Full reset: ALL users + ALL CRM data, then default statuses/booking types/products + calendar row only.
# npm run db:wipe-all:confirm
# Then open /login and sign in with Google (first account = ADMIN).

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Local browsing can stay http://localhost:3000, but RingCentral webhooks need a public HTTPS base. For ngrok dev, set
# APP_URL to the tunnel origin (e.g. https://YOUR_SUBDOMAIN.ngrok-free.app) — exact copy from the ngrok UI, no trailing slash.
APP_URL="http://localhost:3000"
APP_TIMEZONE="America/Toronto"
APP_NAME="Car Systems CRM"

# -----------------------------------------------------------------------------
# Google Calendar (enable Calendar API + OAuth “Web” client in Google Cloud Console)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Must match an authorized redirect URI in the OAuth client (use APP_URL if unset).
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"
# Optional shop-wide fallback when the user who books an appointment has not connected their own Google account in Settings.
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
# Optional shop-wide fallback refresh token (or use per-user connect in Settings instead).
GOOGLE_REFRESH_TOKEN="your-google-refresh-token"

# -----------------------------------------------------------------------------
# Scheduled jobs (optional)
# -----------------------------------------------------------------------------
# Optional: secret for GET /api/ringcentral/sync-cron (e.g. cron-job.org with Authorization: Bearer …).
# Vercel Hobby has no built-in cron; use an external HTTP scheduler or rely on webhook + manual “Sync call logs”.
# CRON_SECRET="long-random-string"
# Optional: while the app is open, refresh server-rendered data while the tab is visible (0 or unset = off).
# Does not affect Google sign-in or a manual browser refresh (F5); only toggles an interval that calls router.refresh().
# Pause from the header “Live sync” toggle (saved in the browser only).
# Use sync or live to match NEXT_PUBLIC_LIVE_ACTIVE_CALL_POLL_SEC (~30s default) instead of a slow fixed cadence.
# NEXT_PUBLIC_UI_LIVE_REFRESH_SEC="sync"
# Or a fixed interval in seconds (min 8, max 120): NEXT_PUBLIC_UI_LIVE_REFRESH_SEC="30"
# How often the browser polls GET /api/ringcentral/active-calls when Live sync is on (seconds, min 30, default 30).
# Too low + multiple tabs + call-log sync share RingCentral quota — raise to 15–20 if the dock shows rate warnings.
# NEXT_PUBLIC_LIVE_ACTIVE_CALL_POLL_SEC="30"
# After RingCentral reports no active lines, keep the “On a call” dock card this many seconds (default 30, min 5, max 120).
# Ghost session rows often cancel a naive timer; the dock ignores same-session ghosts while this countdown runs.
# NEXT_PUBLIC_LIVE_DOCK_POST_CALL_GRACE_SEC="30"

# -----------------------------------------------------------------------------
# RingCentral — read-only on the phone system: call-log + session notifications + recording read proxy (+ optional AI on recordings).
# No answer/hangup/transfer/dial from this CRM. See docs/live-call-dock-setup.md.
#
# Developer Console → your app → Security: enable at least Webhook Subscriptions plus Telephony Sessions (wording may be
# “Telephony Sessions” / session notifications). Webhook Subscriptions alone lets you create a subscription; telephony
# session events need the telephony scope. After adding scopes, generate a new RINGCENTRAL_JWT for this app.
# -----------------------------------------------------------------------------
# RINGCENTRAL_SERVER_URL="https://platform.ringcentral.com"
# RINGCENTRAL_CLIENT_ID=""
# RINGCENTRAL_CLIENT_SECRET=""
# RINGCENTRAL_JWT=""
# CRM User.id to attribute telephony-created call logs (pick a service or admin user UUID from the database).
# RINGCENTRAL_INTEGRATION_USER_ID=""
# Optional: one or more numeric extension **ids** (comma, space, or semicolon). Use ids from GET /account/~/extension
# or `/api/ringcentral/telephony-debug` → accountExtensions — not the Telus device URL id, and extension number (e.g. 102)
# often does not work. When unset, active-calls uses only the JWT user’s extension (~).
# RINGCENTRAL_ACTIVE_CALLS_EXTENSION_ID="111111111,222222222"
# Same as above but clearer for multiple values (either variable may be set; not both needed).
# RINGCENTRAL_ACTIVE_CALLS_EXTENSION_IDS="111111111,222222222"
# When extension id(s) are set, also poll JWT default (~) so you do not drop the line tied to the JWT user.
# RINGCENTRAL_ACTIVE_CALLS_ALSO_POLL_JWT_DEFAULT="true"
# Optional: require ?token= on /api/ringcentral/ai-webhook (set the same value in transcribe webhook URL automatically).
# RINGCENTRAL_WEBHOOK_SECRET=""
# Optional: queue speech-to-text during sync for any imported call that has a recording but no transcript yet.
# You can also click “Request AI transcript” on a client’s call card. Requires RingCentral app **AI** permission
# (often needs RingCentral support to enable) and a **public** HTTPS APP_URL so RingCentral can POST the webhook
# (localhost alone will not receive callbacks unless you use a tunnel). Leave false if unsure.
# RINGCENTRAL_AUTO_TRANSCRIBE="false"
# If account telephony webhooks are registered (Workspace → RingCentral), set true to skip
# GET …/extension/~/active-calls on each dock poll and avoid extra RingCentral API quota.
# RINGCENTRAL_SKIP_EXTENSION_ACTIVE_CALLS="true"
# DB table TelephonyLiveSession (migration 20260406180000_telephony_live_session) is required for telephony webhooks.

# -----------------------------------------------------------------------------
# Optional auth/session secret for production hardening
# -----------------------------------------------------------------------------
AUTH_SECRET="replace-with-a-long-random-secret"

# Dev only: skip /login and use the default seed admin email when no crm-user cookie is set.
# Do not enable in production.
# CRM_ALLOW_DEFAULT_USER="true"
